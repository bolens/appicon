# Normalize text; keep Go / binaries untouched by autocrlf.
* text=auto eol=lf

*.go text eol=lf
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.nix text eol=lf
Makefile text eol=lf

*.svg text eol=lf
*.json text eol=lf

*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.tar.gz binary
*.zip binary
