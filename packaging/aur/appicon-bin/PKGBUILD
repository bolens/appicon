# Maintainer: bolens <https://github.com/bolens>
# Binary AUR package from GitHub release tarballs (no Go toolchain needed).
# Update pkgver + sha256sums_* from release SHA256SUMS before uploading.

pkgname=appicon-bin
pkgver=0.2.0
pkgrel=1
pkgdesc='Resolve desktop and brand icons to local file paths (prebuilt)'
arch=('x86_64' 'aarch64')
url='https://github.com/bolens/appicon'
license=('MIT')
depends=('glibc')
optdepends=(
  'resvg: preferred SVG→PNG rasterizer'
  'librsvg: rsvg-convert SVG→PNG fallback'
)
provides=('appicon')
conflicts=('appicon' 'appicon-git')
options=('!strip')

source_x86_64=("$url/releases/download/v$pkgver/appicon_v${pkgver}_linux_amd64.tar.gz")
source_aarch64=("$url/releases/download/v$pkgver/appicon_v${pkgver}_linux_arm64.tar.gz")
sha256sums_x86_64=('4f7458901a9590f960b421e0733d5578ea9760eb0fb9275f16e965709f893234')
sha256sums_aarch64=('9107145f4cb079906ff5bfecd78124f43895ed145673cf46e91f72c7d36ceeee')

package() {
  install -Dm755 appicon "$pkgdir/usr/bin/appicon"
  if [[ -f completions/appicon.bash ]]; then
    install -Dm644 completions/appicon.bash \
      "$pkgdir/usr/share/bash-completion/completions/appicon"
  fi
  if [[ -f completions/appicon.zsh ]]; then
    install -Dm644 completions/appicon.zsh \
      "$pkgdir/usr/share/zsh/site-functions/_appicon"
  fi
  if [[ -f completions/appicon.fish ]]; then
    install -Dm644 completions/appicon.fish \
      "$pkgdir/usr/share/fish/vendor_completions.d/appicon.fish"
  fi
  if [[ -f man/man1/appicon.1 ]]; then
    install -Dm644 man/man1/appicon.1 "$pkgdir/usr/share/man/man1/appicon.1"
  fi
  if [[ -d contrib/systemd ]]; then
    install -Dm644 contrib/systemd/appicon.socket \
      "$pkgdir/usr/lib/systemd/user/appicon.socket"
    sed 's|^ExecStart=appicon daemon$|ExecStart=/usr/bin/appicon daemon|' \
      contrib/systemd/appicon.service \
      | install -Dm644 /dev/stdin "$pkgdir/usr/lib/systemd/user/appicon.service"
  fi
}
