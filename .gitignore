go.work.sum

# Local CI tool downloads (scripts/ci → .tools/)
.tools/
.cache/

# Release / packaging scratch (assets built into dist/ in CI)
*.tar.gz
*.zip
SHA256SUMS
*.sig
cosign.key

# Nix / direnv (post-v1 flake)
/result
/result-*
.direnv/

# Secrets and local env (none required today; keep out of commits)
.env
.env.*
!.env.example
*.pem
*.key
credentials.json
secrets/

# Editor / IDE
.idea/
.vscode/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

