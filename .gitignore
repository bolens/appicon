# Build outputs (make build / make clean)
/bin/
/dist/
/appicon
*.exe
*.exe~
*.dll
*.so
*.dylib

# Go test binaries and coverage / profiles
*.test
coverage.out
coverage.html
*.coverprofile
*.prof
cpu.out
mem.out
trace.out

# Module scratch (do not vendor deps; no go.work in-tree)
/vendor/
